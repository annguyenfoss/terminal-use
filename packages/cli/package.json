{
  "name": "@terminal-use/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "terminal-use": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@terminal-use/driver-htop": "workspace:*",
    "@terminal-use/driver-nano": "workspace:*",
    "@terminal-use/host": "workspace:*",
    "@terminal-use/protocol": "workspace:*",
    "@terminal-use/sdk": "workspace:*",
    "@terminal-use/testing": "workspace:*"
  }
}
