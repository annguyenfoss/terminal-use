{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@terminal-use/driver-htop": ["../../premium/driver-htop/src/index.ts"],
      "@terminal-use/driver-nano": ["../../premium/driver-nano/src/index.ts"],
      "@terminal-use/host": ["../host/src/index.ts"],
      "@terminal-use/protocol": ["../protocol/src/index.ts"],
      "@terminal-use/sdk": ["../sdk/src/index.ts"],
      "@terminal-use/testing": ["../testing/src/index.ts"]
    },
    "tsBuildInfoFile": "tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "references": [
    { "path": "../../premium/driver-htop" },
    { "path": "../../premium/driver-nano" },
    { "path": "../host" },
    { "path": "../protocol" },
    { "path": "../sdk" },
    { "path": "../testing" }
  ]
}
