{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@project-gateway/driver-htop": ["../../premium/driver-htop/src/index.ts"],
      "@project-gateway/driver-nano": ["../../premium/driver-nano/src/index.ts"],
      "@project-gateway/host": ["../host/src/index.ts"],
