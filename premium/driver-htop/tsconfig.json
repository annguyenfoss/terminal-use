{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@project-gateway/driver-kit": ["../../packages/driver-kit/src/index.ts"],
      "@project-gateway/host": ["../../packages/host/src/index.ts"],
